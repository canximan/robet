# ── Chain ──────────────────────────────────────────────────────────────────
# 31337 = local anvil | 2021 = saigon testnet | 2020 = ronin mainnet
CHAIN_ID=31337
RONIN_RPC_URL=http://127.0.0.1:8545
SAIGON_RPC_URL=https://saigon-testnet.roninchain.com/rpc

# ── Deploy ─────────────────────────────────────────────────────────────────
DEPLOYER_PRIVATE_KEY=
TREASURY_ADDRESS=      # receives: entry fees, 2% pot fee, 10% PoD share
RONIN_EXPLORER_KEY=

# ── Contracts (auto-updated by: cd script && npm run deploy) ───────────────
ROBET_NFT_ADDRESS=
PRICE_FEED_ADDRESS=
BET_POOL_ADDRESS=

# ── Frontend (NEXT_PUBLIC_ mirrors - baked into client bundle at build time) ──
NEXT_PUBLIC_CHAIN_ID=31337
NEXT_PUBLIC_ROBET_NFT=
NEXT_PUBLIC_PRICE_FEED=
NEXT_PUBLIC_BET_POOL=
NEXT_PUBLIC_TREASURY_WALLET=

# ── Keeper ─────────────────────────────────────────────────────────────────
KEEPER_PRIVATE_KEY=
POLL_INTERVAL_MS=5000

# ── Sweeper ────────────────────────────────────────────────────────────────
TREASURY_PRIVATE_KEY=   # private key of the treasury wallet registered with PoD
MIN_SWEEP_RON=1
MAX_SWEEP_RON=100

# ── Mock price bumping (local/testnet only - never set true on mainnet) ────
MOCK_PRICE_BUMP=false
MOCK_OWNER_KEY=         # MockPriceFeed owner key (= DEPLOYER_PRIVATE_KEY)
